[project]
name = "{{ package_name }}"
version = "0.1.0"
description = "Proyecto ML generado con DataForge"
requires-python = ">={{ python_version }}"
dependencies = [
    "pydantic>=2.9.0",
    "pydantic-settings>=2.5.0",
    "psycopg[binary,pool]>=3.2.0",
    "python-dotenv>=1.0.0",
    "httpx>=0.27.0",
    "rich>=13.9.0",
]

[project.optional-dependencies]
ml = [
    "scikit-learn>=1.5.0",
    "numpy>=1.26.0",
    "pandas>=2.2.0",
    "joblib>=1.4.0",
]
dev = [
    "pytest>=8.0",
    "ruff>=0.7",
    "jupytext>=1.16",
    "ipython>=8.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.ruff]
target-version = "py312"
line-length = 100

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]
