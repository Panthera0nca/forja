"""Métricas y cross-validation framework-agnostic.

Usá `cross_validate` antes de reportar cualquier resultado.
Un modelo que solo fue evaluado en un split puede estar overfitteado.
"""
from __future__ import annotations

import numpy as np
from sklearn.model_selection import StratifiedKFold, KFold
from sklearn.metrics import (
    accuracy_score,
    f1_score,
    mean_absolute_error,
    mean_squared_error,
    r2_score,
)

from {{ package_name }}.models.base import Predictor


def evaluate(
    model: Predictor,
    X: np.ndarray,
    y: np.ndarray,
    task: str = "classification",
) -> dict[str, float]:
    """Evalúa el modelo sobre un conjunto de datos.

    Args:
        task: "classification" | "regression"
    """
    y_pred = model.predict(X)
    if task == "classification":
        return {
            "accuracy": float(accuracy_score(y, y_pred)),
            "f1_macro": float(f1_score(y, y_pred, average="macro", zero_division=0)),
        }
    return {
        "mae":  float(mean_absolute_error(y, y_pred)),
        "rmse": float(np.sqrt(mean_squared_error(y, y_pred))),
        "r2":   float(r2_score(y, y_pred)),
    }


def cross_validate(
    model_factory,
    X: np.ndarray,
    y: np.ndarray,
    n_splits: int = 5,
    task: str = "classification",
) -> dict[str, float]:
    """Cross-validation con k folds. Retorna promedio ± std de cada métrica.

    Args:
        model_factory: callable sin argumentos que retorna un Predictor nuevo.
                       Ejemplo: lambda: RandomForestClassifier(n_estimators=100)
        n_splits: número de folds (default 5).
        task: "classification" | "regression"
    """
    kf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=42) \
        if task == "classification" else KFold(n_splits=n_splits, shuffle=True, random_state=42)

    fold_metrics: list[dict[str, float]] = []
    for train_idx, val_idx in kf.split(X, y if task == "classification" else np.zeros(len(y))):
        model = model_factory()
        model.fit(X[train_idx], y[train_idx])
        fold_metrics.append(evaluate(model, X[val_idx], y[val_idx], task=task))

    keys = fold_metrics[0].keys()
    return {
        **{k: float(np.mean([m[k] for m in fold_metrics])) for k in keys},
        **{f"{k}_std": float(np.std([m[k] for m in fold_metrics])) for k in keys},
    }
