# Manifest del proyecto DataForge. Lo usa el CLI `dfg` para detectar y operar.
[project]
name = "{{ project_name }}"
package = "{{ package_name }}"
type = "ml"
version = "0.1.0"
forja_version = "{{ forja_version }}"
category = "{{ category }}"
sources = []
pipelines = []

[ml]
framework = "scikit-learn"   # cambiá a "pytorch" o "xgboost" según necesites
tracking = "stdout"          # opciones: stdout | mlflow | wandb
