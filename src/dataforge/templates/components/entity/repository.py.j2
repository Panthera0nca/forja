"""Repositorio para {{ class_name }} — Operaciones CRUD con SQL Crudo."""
from __future__ import annotations

from typing import Optional, Sequence

from {{ package_name }}.db.connection import get_connection
from {{ package_name }}.dtos.{{ entity_name }} import {{ class_name }}


class {{ class_name }}Repository:
    """Acceso a datos para la tabla '{{ table_name }}'."""

    def save(self, entity: {{ class_name }}) -> {{ class_name }}:
        """Inserta o actualiza un registro."""
        if entity.id is None:
            return self._insert(entity)
        return self._update(entity)

    def _insert(self, entity: {{ class_name }}) -> {{ class_name }}:
        query = """
            INSERT INTO {{ table_name }} (name, updated_at)
            VALUES (%(name)s, NOW())
            RETURNING id, created_at, updated_at;
        """
        with get_connection() as conn:
            with conn.cursor() as cur:
                cur.execute(query, entity.model_dump(exclude={"id", "created_at", "updated_at"}))
                row = cur.fetchone()
                if row:
                    entity.id, entity.created_at, entity.updated_at = row
        return entity

    def _update(self, entity: {{ class_name }}) -> {{ class_name }}:
        query = """
            UPDATE {{ table_name }}
            SET name = %(name)s, updated_at = NOW()
            WHERE id = %(id)s
            RETURNING updated_at;
        """
        with get_connection() as conn:
            with conn.cursor() as cur:
                cur.execute(query, entity.model_dump(exclude={"created_at", "updated_at"}))
                row = cur.fetchone()
                if row:
                    entity.updated_at = row[0]
        return entity

    def find_by_id(self, entity_id: int) -> Optional[{{ class_name }}]:
        """Busca un registro por su ID."""
        query = "SELECT * FROM {{ table_name }} WHERE id = %s;"
        with get_connection() as conn:
            with conn.cursor() as cur:
                cur.execute(query, (entity_id,))
                row = cur.fetchone()
                if row:
                    colnames = [desc[0] for desc in cur.description]
                    return {{ class_name }}(**dict(zip(colnames, row)))
        return None

    def list_all(self, limit: int = 100) -> Sequence[{{ class_name }}]:
        """Lista todos los registros."""
        query = "SELECT * FROM {{ table_name }} ORDER BY id DESC LIMIT %s;"
        entities = []
        with get_connection() as conn:
            with conn.cursor() as cur:
                cur.execute(query, (limit,))
                colnames = [desc[0] for desc in cur.description]
                for row in cur.fetchall():
                    entities.append({{ class_name }}(**dict(zip(colnames, row))))
        return entities
