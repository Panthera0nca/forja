[project]
name = "{{ package_name }}"
version = "0.1.0"
description = "Proyecto {{ domain }} generado con DataForge (arquitectura hexagonal)"
requires-python = ">={{ python_version }}"
dependencies = [
    "pydantic>=2.9.0",
    "pydantic-settings>=2.5.0",
    "psycopg[binary,pool]>=3.2.0",
    "python-dotenv>=1.0.0",
    "rich>=13.9.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "ruff>=0.7",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.ruff]
target-version = "py312"
line-length = 100

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]
